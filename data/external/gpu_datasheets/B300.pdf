  <script>
    if (location.hostname === 'resources.nvidia.cn') {
        // Utility function to wait for an element to appear
        function waitForElement(selector, callback) {
            // If it's already there, run the callback immediately
            if ($(selector).length) {
                callback();
                return;
            }
            // Otherwise, watch the DOM for changes
            const observer = new MutationObserver(function(mutations, obs) {
                if ($(selector).length) {
                    obs.disconnect(); // Stop watching once found
                    callback();
                }
            });
            observer.observe(document.body, { childList: true, subtree: true });
        }

        $(document).ready(function() {
            // Wait for and hide the share element
            waitForElement("#qa-share-common", function() {
                $("#qa-share-common").hide();
            });

            // Wait for and update the logo link
            waitForElement("#qa-logo-common a", function() {
                $("#qa-logo-common a").attr("href", "https://www.nvidia.cn/");
            });
        });
    }
</script>

