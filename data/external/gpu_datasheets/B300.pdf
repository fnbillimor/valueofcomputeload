  <script>
    var mode;
  
    addElement();
    window.addEventListener("resize", addElement);
  
    function addElement() {
      if (mode === "desktop" && window.innerWidth > 800) { return; }
      if (mode === "mobile" && window.innerWidth <= 800) { return; }
  
      mode = window.innerWidth > 800 ? "desktop" : "mobile";
  
      if (mode === "mobile") { return; }
  
      var retry = 0;
      var timer = window.setInterval(function() {
        if (retry > 20) { clearInterval(timer); }
  
        var lbApp = document.getElementById("qa-app-base");
        if (lbApp) {
          var header = document.querySelector(".mainHeader_ .message_");
  
          if (!header) {
            header = document.querySelector(".headerContainer_ > div");
          }
  
          if (!header) { return; }
  
          var container = document.createElement("div");
          container.className = "cta-container";
          var ctaTitle = document.createElement("div");
          ctaTitle.className = "cta-title";
          //ctaTitle.innerText = titleText;
          ctaTitle.innerHTML = titleText;
          
          var ctaButtonContainer = document.createElement("div");
          var cta = document.createElement("a");
          cta.className = "cta-button";
          cta.href = linkUrl;
          cta.innerText = linkText;
          cta.target = "_blank";
          ctaButtonContainer.appendChild(cta);
  
          container.appendChild(ctaTitle);
          container.appendChild(ctaButtonContainer);
          header.appendChild(container);
  
          clearInterval(timer);
        }
        retry++;
  
      }, 200);
    }
  </script>
  
