<style>
  .cta-title {
    font-size: 14px;
    margin-bottom: 1rem;
    padding: 0 10px;
  }
  .dev-header {
      color: #76b900;
      text-transform: none;
      padding-bottom: 10px;
  }
  .cta-button {
    font-size: 16px;
    font-weight: bold;
    padding: .5rem 1rem;
    color: #000000 !important;
    border: 1px solid #76b900;
    background-color: #76b900;
    text-decoration: none;
    -webkit-font-smoothing: antialiased;
    display: block;
    width: 130px;
    margin: 0 auto;
  }
  .cta-container { font-family: NVIDIA-NALA,Arial,Helvetica,Sans-Serif; text-align: center; padding: 15px; margin-left: auto; }
  .message_ { display: flex; align-items: center; }
  .message_ .cta-container { padding: 0 10px 0 0; }
</style>
<!-- END CONFIGURATION -->
<script>
  var mode;

  addElement();
  window.addEventListener("resize", addElement);

  function addElement() {
    if (mode === "desktop" && window.innerWidth > 800) { return; }
    if (mode === "mobile" && window.innerWidth <= 800) { return; }

    mode = window.innerWidth > 800 ? "desktop" : "mobile";

    if (mode === "mobile") { return; }

    var retry = 0;
    var timer = window.setInterval(function() {
      if (retry > 20) { clearInterval(timer); }

      var lbApp = document.getElementById("qa-app-base");
      if (lbApp) {
        var header = document.querySelector(".mainHeader_ .message_");

        if (!header) {
          header = document.querySelector(".headerContainer_ > div");
        }

        if (!header) { return; }

        var container = document.createElement("div");
        container.className = "cta-container";
        var ctaTitle = document.createElement("div");
        ctaTitle.className = "cta-title";
        //ctaTitle.innerText = titleText;
        ctaTitle.innerHTML = titleText;
        
        var ctaButtonContainer = document.createElement("div");
        var cta = document.createElement("a");
        cta.className = "cta-button";
        cta.href = linkUrl;
        cta.innerText = linkText;
        cta.target = "_blank";
        ctaButtonContainer.appendChild(cta);

        container.appendChild(ctaTitle);
        container.appendChild(ctaButtonContainer);
        header.appendChild(container);

        clearInterval(timer);
      }
      retry++;

    }, 200);
  }
</script>

  <script>
// Create IE + others compatible event handler
var eventMethod = window.addEventListener ? "addEventListener" : "attachEvent";
var eventer = window[eventMethod];
var messageEvent = eventMethod == "attachEvent" ? "onmessage" : "message";
// Listen to message from child window
eventer(messageEvent,function(e) {
  try{
 if (typeof e.data=== 'string'){
  const data = JSON.parse(e.data);
  const redirectURL = data.message;
if(redirectURL && redirectURL !==''){
  window.open(redirectURL, "_blank");
}
}
}catch(ex){
}
},false);
</script>
