      <style>
        * { box-sizing: border-box; }
        body, html { margin: 0; padding: 0; overflow: hidden; height: 100%; font-family: "Helvetica Neue", Helvetica, Arial, sans-serif; }
        #lookbook-video-player { width: 100%; height: 100%; overflow: hidden; }
        #lb-app-container {
          position: absolute;
          top: 0;
          left: 0;
          right: 0;
          bottom: 0;
          -webkit-overflow-scrolling: touch;
          background: #fff;
          overflow: auto;
        }
        .standard { height: 100%; width: 100%; margin: 0; }
        .overlay {
          height: 100%;
          width: 100%;
          margin: auto;
          position: absolute;
          top: 0;
          left: 0;
          right: 0;
          bottom: 0;
        }
        @media (max-width: 480px) {
          .overlay { height: 100%; width: 100%; }
        }
      </style>

  <script type="text/javascript" src="https://releases.jquery.com/git/jquery-3.x-git.min.js"></script>
<script>
    const intervalTimer = setInterval(() => {
        if(document.getElementsByClassName('pf-microsite-card-title').length){
            clearInterval(intervalTimer);
            const contentTypeTags =  document.getElementsByClassName('pf-carousel-item');
            console.log('contenttypetag is')
            console.log(contentTypeTags)
          var arr = Array.from(contentTypeTags);
            arr.forEach((contentTypeTag) => {
                var tagContainer = contentTypeTag.querySelector('.pf-microsite-card-title').previousSibling
                    tagContainer.insertAdjacentElement('afterEnd',contentTypeTag.querySelector("[data-qa-hook='content-type-asset']") )
                    if (contentTypeTag.querySelector("[data-qa-hook='content-type-asset']").innerText.toLowerCase()=='video'){
                        var thumbnailcontainer = contentTypeTag.querySelector("[data-qa-hook='content-type-asset']").previousSibling
                        thumbnailcontainer.insertAdjacentHTML('afterBegin','<div class="play-button"></div>')
                    }
                    if (contentTypeTag.querySelector("[data-qa-hook='content-type-asset']").innerText.toLowerCase()=='webinar'){
                        var thumbnailcontainer = contentTypeTag.querySelector("[data-qa-hook='content-type-asset']").previousSibling
                        thumbnailcontainer.insertAdjacentHTML('afterBegin','<div class="play-button"></div>')
                    }
                    if (contentTypeTag.querySelector("[data-qa-hook='content-type-asset']").innerText.toLowerCase()=='gtc session'){
                        var thumbnailcontainer = contentTypeTag.querySelector("[data-qa-hook='content-type-asset']").previousSibling
                        thumbnailcontainer.insertAdjacentHTML('afterBegin','<div class="play-button"></div>')
                    }
                    if (contentTypeTag.querySelector("[data-qa-hook='content-type-asset']").innerText.toLowerCase()=='session'){
                        var thumbnailcontainer = contentTypeTag.querySelector("[data-qa-hook='content-type-asset']").previousSibling
                        thumbnailcontainer.insertAdjacentHTML('afterBegin','<div class="play-button"></div>')
                    }
            })
        }
    },600)
</script>
<style>
body {
    font-family: NVIDIA-NALA,Arial,Helvetica,Sans-Serif !important;
}
/*hide filters*/
.bORbIW {
    display: none !important;
}
/*microsite*/
.slick-slide {
    padding: 0px 15px !important;
    min-width:300px;
}
.lookbook-overlay-close-wrapper #lookbook-overlay-close.lookbook-overlay-close, .lookbook-overlay-close, #lookbook-overlay-close {
  background-color: rgb(255,255,255) !important;
  color: white !important;
}
.slick-slider {
max-width: 95%;
margin: auto;
}
.pf-microsite-card-title > div{
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow-wrap: break-word;
  max-height:75px;
}
.slick-list {
    margin:0px !important;
    padding:0px !important;
    padding-bottom: 30px !important;
}
.pf-microsite-card-title {
    padding: 18px 30px 30px 30px !important;
}
.pf-microsite-card-link {
    height: 100%;
}
.pf-microsite-card {
    border-width: 0px !important;
}
.pf-track-block {
    padding:0px !important;
}
div[data-qa-hook="content-type-asset"] {
    position: relative !important;
    left: 0 !important;
    top: 0px !important;
    margin-bottom: 0 !important;
    color: #333 !important;
    background-color: transparent !important;
    border-color: transparent !important;
    box-shadow: none !important;
    padding: 30px 0px 0px 30px!important;
}
.pf-microsite-card, .pf-explore-asset-container {
-moz-border-radius: 3px !important;
-webkit-border-radius: 3px !important; 
border-radius: 3px !important;
box-shadow: 0 3px 6px rgb(0 0 0 / 16%) !important;
-webkit-box-shadow: 0 3px 6px rgb(0 0 0 / 16%) !important;
background-color: #fff !important;
}
.pf-microsite-card:hover {
box-shadow: 0 4px 8px rgb(0 0 0 / 24%) !important;
-webkit-box-shadow: 0 4px 8px rgb(0 0 0 / 24%) !important;
}
img.pf-microsite-card-image, img.pf-explore-asset-image {
  -moz-border-radius-topleft: 3px !important;
  -webkit-border-top-left-radius: 3px !important;
  border-top-left-radius: 3px !important;
    -moz-border-radius-topright: 3px !important;
  -webkit-border-top-right-radius: 3px !important;
  border-top-right-radius: 3px !important;
}
img.pf-microsite-card-image {
    object-position:top;
}
.slick-arrow i {
text-shadow: none !important;
color: #999999 !important;
}
.play-button {
    position: absolute;
    width: 56px;
    height: 56px;
    background-color: rgba(0,0,0,0);
    border-radius: none;
    top: 35%;
    left: 40%;
    margin: 0px !important;
    cursor: pointer;
    z-index: 9999;
    border: none !important;
    background-image: url('https://www.nvidia.com/content/dam/icons/play-button-pathfactory.svg');
    background-repeat: no-repeat;
}
.play-button:after {
    border-width: 0px !important;
    border-style: none !important;
    border-color: transparent !important;
}
.css-1lckzle{
    aspect-ratio: 16 / 9 !important;
}
.css-6jaxb6{
    padding-bottom: 57% !important;
}
.chip {
    background: #76b900 !important;
    color: #ffffff !important;
}
.closebtn {
    color: #ffffff !important;
}
.slick-next {
    background-color: transparent !important;
}
.slick-prev {
    background-color: transparent !important;
}
.eUpLud .slick-list {
    height: auto !important;
}
.pf-in-page-carousel-arrow {
    color:#1a1a1a !important;
}
#microsite_search_input {
    height: 32px;
