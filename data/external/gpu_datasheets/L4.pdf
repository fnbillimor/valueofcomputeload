<script>
window.addEventListener("load", function() {
    let count = 0;
    const interval = setInterval(function () {
        const pfConciergeGroup = document.querySelector('.pf-track-block');
        if (count === 10) clearInterval(interval);
        if (pfConciergeGroup) {
            clearInterval(interval);
            var elements = document.getElementsByClassName("pf-microsite-card");
            for (let item of elements) {
                try {
                    item.addEventListener('click', function(e) {
                        // e.stopPropagation();
                        const anchors = e.currentTarget.getElementsByTagName('a');
                        const anchorHref = anchors.length && anchors[0].href
                        const message = {
                          contentUrl: anchorHref,
                        };
                        window.parent.postMessage(message, "*");
                        return;
                    });
                } catch (e) {
                    alert(e);
                }
            }
        } else {
            count++;
        }
    }, 1000);
}, false);
</script>
